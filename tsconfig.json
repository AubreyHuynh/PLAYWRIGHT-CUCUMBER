{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@src/*": ["./src/*"],
      "@steps/*": ["./steps/*"],
      "@features/*": ["./features/*"],
      "@config/*": ["./src/config/*"],
      "@pages/*": ["./src/pages/*"],
      "@components/*": ["./src/components/*"],
      "@locators/*": ["./src/locators/*"],
      "@flows/*": ["./src/flows/*"],
      "@api/*": ["./src/api/*"],
      "@db/*": ["./src/db/*"],
      "@data/*": ["./src/data/*"],
      "@utils/*": ["./src/utils/*"],
      "@fixtures/*": ["./src/fixtures/*"],
      "@support/*": ["./support/*"]
    }
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    },
    "transpileOnly": true
  },
  "include": ["src/**/*", "support/**/*", "steps/**/*", "features/**/*"],
  "exclude": ["node_modules", "dist", "reports"]
}
